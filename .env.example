# Base Sepolia RPC (optional; defaults to https://sepolia.base.org)
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deploy contracts/BoomboxScore.sol with Foundry, then paste address:
NEXT_PUBLIC_SCORE_CONTRACT_ADDRESS=
NEXT_PUBLIC_GAME_CONTRACT_ADDRESS=
NEXT_PUBLIC_BOOM_TOKEN_ADDRESS=0x

# Set to "true" for Base mainnet instead of Base Sepolia
# NEXT_PUBLIC_USE_MAINNET=false
