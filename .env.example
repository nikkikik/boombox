# Optional: custom Base Mainnet RPC (defaults to https://mainnet.base.org)
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Contract addresses are hard-coded in src/constants/addresses.ts (v2 mainnet):
# TOKEN  0x63bBE8362b4e25D51AD0A86c7e45d3B2779E5f6C
# GAME   0xc45D9d59842128eFb32E2644a227431c62d0919A

# Optional: Etherscan API key for contract verification scripts (local only, never commit)
# ETHERSCAN_API_KEY=

# Farcaster Mini App manifest (production URL, no trailing slash)
NEXT_PUBLIC_APP_URL=https://boombox-one.vercel.app

# Base Builder Code for onchain transaction attribution (base.dev → Settings → Builder Codes)
NEXT_PUBLIC_BUILDER_CODE=bc_8btj5ztw

# Optional override — defaults are in src/lib/farcasterManifest.ts
# FARCASTER_ACCOUNT_ASSOCIATION_HEADER=
# FARCASTER_ACCOUNT_ASSOCIATION_PAYLOAD=
# FARCASTER_ACCOUNT_ASSOCIATION_SIGNATURE=
