# --- Base Mainnet (production) ---
# Run: export DEPLOYER_PRIVATE_KEY=0x... && npm run deploy:mainnet
NEXT_PUBLIC_USE_MAINNET=true
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BOOM_TOKEN_ADDRESS=
NEXT_PUBLIC_GAME_CONTRACT_ADDRESS=

# --- Base Sepolia (local dev) — copy to .env.local ---
# NEXT_PUBLIC_USE_MAINNET=false
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# NEXT_PUBLIC_BOOM_TOKEN_ADDRESS=
# NEXT_PUBLIC_GAME_CONTRACT_ADDRESS=

NEXT_PUBLIC_SCORE_CONTRACT_ADDRESS=
